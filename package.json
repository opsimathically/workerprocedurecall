{
  "name": "@opsimathically/workerprocedurecall",
  "version": "0.0.2",
  "description": "Worker-thread RPC for Node.js with dynamic function, dependency, and constant registration via message passing.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npx ts-to-zod && tsup",
    "test": "node --require ts-node/register --require tsconfig-paths/register --test test/**/*.test.ts",
    "test:fuzz": "FUZZ_ITERS=200 FUZZ_CASE_TIMEOUT_MS=600 node --require ts-node/register --require tsconfig-paths/register --test test/fuzz_test/*.test.ts",
    "test:fuzz:quick": "FUZZ_ITERS=25 FUZZ_CASE_TIMEOUT_MS=350 node --require ts-node/register --require tsconfig-paths/register --test test/fuzz_test/*.test.ts",
    "test:fuzz:replay": "node --require ts-node/register --require tsconfig-paths/register --test test/fuzz_test/*.test.ts",
    "benchmark:worker-vs-single": "node --require ts-node/register --require tsconfig-paths/register benchmarking/worker_vs_single_thread.benchmark.ts",
    "benchmark:worker-vs-single-sha1": "node --require ts-node/register --require tsconfig-paths/register benchmarking/worker_vs_single_thread_sha1.benchmark.ts",
    "benchmark:worker-vs-single-sha1-heavy": "node --require ts-node/register --require tsconfig-paths/register benchmarking/worker_vs_single_thread_sha1_heavy.benchmark.ts",
    "benchmark:shared-vs-ipc": "node --require ts-node/register --require tsconfig-paths/register benchmarking/shared_memory_vs_ipc.benchmark.ts",
    "benchmark:shared-vs-ipc-heavy": "node --require ts-node/register --require tsconfig-paths/register benchmarking/shared_memory_vs_ipc_heavy.benchmark.ts",
    "manual:network-transport-mvp": "node --require ts-node/register --require tsconfig-paths/register manual_testing/network_transport_mvp.ts",
    "test:chaos-phase13": "node --require ts-node/register --require tsconfig-paths/register --test test/any_test/cluster_operations_phase13.test.ts",
    "lab:up:minimal": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts up --profile=minimal",
    "lab:up:ingress": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts up --profile=ingress",
    "lab:up:cluster": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts up --profile=cluster",
    "lab:up:geo": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts up --profile=geo",
    "lab:down": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts down",
    "lab:status": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts status",
    "lab:logs": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts logs",
    "lab:logs:service": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts logs",
    "lab:logs:follow": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts logs",
    "lab:snapshot": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts snapshot",
    "lab:snapshot:service": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts snapshot",
    "lab:scenario:happy_path": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=happy_path_call",
    "lab:scenario:ingress_failover": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=ingress_failover",
    "lab:scenario:discovery_membership_and_expiry": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=discovery_membership_and_expiry",
    "lab:scenario:control_plane_policy_sync": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=control_plane_policy_sync",
    "lab:scenario:geo_cross_region_failover": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=geo_cross_region_failover",
    "lab:scenario:auth_failure": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=auth_failure",
    "lab:scenario:stale_control_fail_closed": "node --require ts-node/register --require tsconfig-paths/register local_cluster_lab/cli.ts run-scenario --name=stale_control_fail_closed",
    "ts-to-zod": "npx ts-to-zod",
    "docs": "typedoc"
  },
  "keywords": [
    "set_keywords"
  ],
  "homepage": "https://github.com/opsimathically/workerprocedurecall",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/node-forge": "^1.3.11",
    "@types/pg": "^8.16.0",
    "@types/wtfnode": "^0.7.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.1",
    "typedoc-plugin-markdown": "^4.6.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "wtfnode": "^0.10.0"
  },
  "author": "Jason Medeiros",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opsimathically/workerprocedurecall.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@swc/core": "^1.11.24",
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "better-sqlite3": "^12.6.2",
    "command-line-args": "^6.0.1",
    "command-line-usage": "^7.0.3",
    "mongodb": "^7.1.0",
    "mysql2": "^3.18.1",
    "pg": "^8.19.0",
    "sharp": "^0.34.1",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "ts-to-zod": "^5.1.0",
    "zod": "^4.3.5"
  }
}
